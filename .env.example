# ── CORA base settings ─────────────────────────────────────────────────────────
CORA_CONTROL_SYSTEM=epics
CORA_DATABASE_URL=postgresql+asyncpg://cora:cora@localhost:5432/cora
CORA_NATS_URL=nats://localhost:4222
CORA_ANTHROPIC_API_KEY=sk-ant-...
CORA_HOME_FACILITY=aps
CORA_DEBUG=false
CORA_LOG_LEVEL=INFO

# APS machine status PVs (already default to these in CORA, shown for clarity)
CORA_PV_BEAM_CURRENT=S:SRcurrentAI
CORA_PV_BEAM_ENERGY=S:Energy
CORA_PV_MACHINE_MODE=S:ActualMode
CORA_PV_BEAM_LIFETIME=S:BeamLifeTimeAI
CORA_PV_REFILL_INTERVAL=S:TopUpPeriod
CORA_EPICS_CA_TIMEOUT=5.0

# APS safety / scheduling
CORA_ESAF_API_URL=https://beam.aps.anl.gov/pls/apsweb/esaf100.start_page
CORA_ESAF_API_TOKEN=

# Automation pipeline IDs (set after registering pipelines via the API)
CORA_AUTO_ANALYSIS_PIPELINE_ID=tomocupy
CORA_FAULT_WORKFLOW_ID=
CORA_RETRY_WORKFLOW_ID=

# ── 2-BM beamline settings ─────────────────────────────────────────────────────
CORA_2BM_HUTCH=A                        # "A" or "B"

# Rotation stage PV bases
CORA_2BM_PV_ROT_STAGE_A=2bma:m49
CORA_2BM_PV_ROT_STAGE_B=2bmb:m1

# Sample stage PV bases — hutch A
CORA_2BM_PV_SAMPLE_TOP_X_A=2bma:m41
CORA_2BM_PV_SAMPLE_TOP_Z_A=2bma:m42
CORA_2BM_PV_SAMPLE_Y_A=2bma:m44

# Sample stage PV bases — hutch B
CORA_2BM_PV_SAMPLE_TOP_X_B=2bmb:m46
CORA_2BM_PV_SAMPLE_TOP_Z_B=2bmb:m47
CORA_2BM_PV_SAMPLE_Y_B=2bmb:m44

# Detector AreaDetector IOC prefixes
CORA_2BM_PV_DETECTOR_PREFIX_A=2bma:Oryx1:
CORA_2BM_PV_DETECTOR_PREFIX_B=2bmb:Oryx1:

# TomoScan IOC prefixes
CORA_2BM_PV_TOMOSCAN_PREFIX_A=2bma:TomoScan:
CORA_2BM_PV_TOMOSCAN_PREFIX_B=2bmb:TomoScan:

# Data paths
CORA_2BM_DATA_ROOT=/local/data           # fast NVMe, written during acquisition
CORA_2BM_ARCHIVE_ROOT=/data/2bm          # GPFS long-term storage

# Reconstruction
CORA_2BM_RECON_BACKEND=tomocupy          # "tomopy" or "tomocupy"
CORA_2BM_RECON_EXTRA_ARGS=--remove-stripe-method fw --rotation-axis-auto auto
CORA_2BM_TOMOPY_SCRIPT=tomopy
CORA_2BM_TOMOCUPY_SCRIPT=tomocupy
